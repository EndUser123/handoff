{
  "PreCompact": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "python \"$CLAUDE_PLUGIN_ROOT/scripts/hooks/PreCompact_handoff_capture.py\""
        },
        {
          "type": "command",
          "command": "python \"$CLAUDE_PLUGIN_ROOT/scripts/hooks/precompact_imports_patch.py\""
        }
      ]
    }
  ],
  "SessionStart": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "python \"$CLAUDE_PLUGIN_ROOT/scripts/hooks/SessionStart_handoff_restore.py\""
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "python \"$CLAUDE_PLUGIN_ROOT/scripts/hooks/userpromptsubmit_task_injector.py\""
        }
      ]
    }
  ]
}
